        x0 = q^-2 + q^-1 + 2 + 2*q + 2*q^2 + 3*q^3 + 4*q^4 - 2*q^5 - q^6 + q^7 - 4*q^8 - 2*q^9 - 6*q^10 - 10*q^11 + 8*q^12 + 6*q^13 - 3*q^14 + 10*q^15 + 4*q^16 + 12*q^17 + 22*q^18 - 15*q^19 - 16*q^20 + 6*q^21 - 18*q^22 - 12*q^23 - 24*q^24 - 46*q^25 + 26*q^26 + 32*q^27 - 12*q^28 + 32*q^29 + 26*q^30 + 49*q^31 + 92*q^32 - 52*q^33 - 60*q^34 + 25*q^35 - 60*q^36 - 40*q^37 - 91*q^38 - 168*q^39 + 96*q^40 + 112*q^41 - 46*q^42 + 102*q^43 + 64*q^44 + 154*q^45 + 292*q^46 - 160*q^47 - 200*q^48 + 78*q^49 - 166*q^50 - 118*q^51 - 256*q^52 - 500*q^53 + 264*q^54 + 337*q^55 - 132*q^56 + 276*q^57 + 200*q^58 + 427*q^59 + 832*q^60 - 434*q^61 - 551*q^62 + 220*q^63 - 444*q^64 - 308*q^65 - 692*q^66 - 1340*q^67 + 696*q^68 + 892*q^69 - 355*q^70 + 690*q^71 + 476*q^72 + 1080*q^73 + 2112*q^74 - 1083*q^75 - 1416*q^76 + 556*q^77 - 1064*q^78 - 754*q^79 - 1664*q^80 - 3282*q^81 + 1656*q^82 + 2187*q^83 - 856*q^84 + 1620*q^85 + 1166*q^86 + 2553*q^87 + 5024*q^88 - 2520*q^89 - 3322*q^90 + 1309*q^91 - 2432*q^92 - 1728*q^93 - 3848*q^94 - 7558*q^95 + 3784*q^96 + 5004*q^97 - 1970*q^98 + 3602*q^99 + 2540*q^100 + 5690*q^101 + 11218*q^102 - 5576*q^103 - 7440*q^104 + 2908*q^105 - 5268*q^106 - 3764*q^107 - 8336*q^108 - 16488*q^109 + 8129*q^110 + 10890*q^111 - 4252*q^112 + 7648*q^113 + 5500*q^114 + 12130*q^115 + 23976*q^116 - 11782*q^117 + O(q^118)
        y0 = q^-3 + q^-2 + 3*q^-1 + 3 + 7*q + 6*q^2 + 5*q^3 + 8*q^4 + 8*q^5 - q^6 - 3*q^7 - 16*q^8 - 11*q^9 + 2*q^10 - 26*q^11 - 24*q^12 + 10*q^13 + 9*q^14 + 42*q^15 + 40*q^16 - 14*q^17 + 74*q^18 + 79*q^19 - 40*q^20 - 25*q^21 - 98*q^22 - 112*q^23 + 40*q^24 - 179*q^25 - 222*q^26 + 104*q^27 + 64*q^28 + 219*q^29 + 250*q^30 - 109*q^31 + 400*q^32 + 528*q^33 - 212*q^34 - 145*q^35 - 456*q^36 - 522*q^37 + 261*q^38 - 836*q^39 - 1144*q^40 + 426*q^41 + 306*q^42 + 910*q^43 + 1072*q^44 - 578*q^45 + 1668*q^46 + 2360*q^47 - 872*q^48 - 619*q^49 - 1770*q^50 - 2114*q^51 + 1192*q^52 - 3203*q^53 - 4664*q^54 + 1675*q^55 + 1208*q^56 + 3328*q^57 + 3968*q^58 - 2315*q^59 + 5920*q^60 + 8834*q^61 - 3015*q^62 - 2270*q^63 - 6040*q^64 - 7214*q^65 + 4364*q^66 - 10624*q^67 - 16160*q^68 + 5330*q^69 + 4117*q^70 + 10686*q^71 + 12864*q^72 - 7982*q^73 + 18648*q^74 + 28787*q^75 - 9352*q^76 - 7289*q^77 - 18568*q^78 - 22422*q^79 + 14120*q^80 - 32037*q^81 - 50112*q^82 + 15981*q^83 + 12648*q^84 + 31623*q^85 + 38142*q^86 - 24373*q^87 + 53904*q^88 + 85358*q^89 - 26578*q^90 - 21469*q^91 - 52768*q^92 - 63689*q^93 + 41304*q^94 - 89150*q^95 - 142584*q^96 + 43594*q^97 + 35730*q^98 + 86666*q^99 + 104808*q^100 - 68702*q^101 + 145298*q^102 + 234248*q^103 - 70760*q^104 - 58536*q^105 - 140444*q^106 - 169912*q^107 + 112240*q^108 - 233453*q^109 - 379167*q^110 + 113134*q^111 + 94544*q^112 + 224478*q^113 + 271388*q^114 - 180650*q^115 + 370080*q^116 + O(q^117)
