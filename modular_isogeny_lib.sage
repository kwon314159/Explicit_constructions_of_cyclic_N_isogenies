def get_X0_generators(N, q):
    """
    Returns the generators (x0, y0) for the function field of X0(N) as q-expansions.
    Add cases for other N here.
    """
    if N == 11:
        # Y. Yang's basis for X0(11)
        x0 = q^-2 + 2*q^-1 + 4 + 5*q + 8*q^2 + q^3 + 7*q^4 - 11*q^5 + 10*q^6 - 12*q^7 - 18*q^8 - 22*q^9 + 26*q^10 - 11*q^11 + 41*q^12 + 44*q^13 - 15*q^14 + 25*q^15 - 66*q^16 + 54*q^17 - 34*q^18 - 132*q^19 - 165*q^20 + 178*q^21 - 55*q^22 + 189*q^23 + 222*q^24 - 48*q^25 + 92*q^26 - 269*q^27 + 274*q^28 - 112*q^29 - 572*q^30 - 767*q^31 + 756*q^32 - 209*q^33 + 720*q^34 + 814*q^35 - 218*q^36 + 303*q^37 - 930*q^38 + 1006*q^39 - 262*q^40 - 2064*q^41 - 2792*q^42 + 2690*q^43 - 693*q^44 + 2366*q^45 + 2626*q^46 - 660*q^47 + 902*q^48 - 2831*q^49 + 3222*q^50 - 674*q^51 - 6412*q^52 - 8742*q^53 + 8230*q^54 - 2035*q^55 + 6916*q^56 + 7584*q^57 - 2000*q^58 + 2419*q^59 - 7903*q^60 + 9228*q^61 - 1484*q^62 - 18070*q^63 - 24704*q^64 + 22996*q^65 - 5522*q^66 + 18639*q^67 + 20322*q^68 - 5251*q^69 + 6234*q^70 - 20533*q^71 + 24408*q^72 - 3380*q^73 - 47058*q^74 - 64420*q^75 + 59296*q^76 - 13970*q^77 + 46981*q^78 + 50834*q^79 - 13318*q^80 + 15029*q^81 - 50316*q^82 + 60450*q^83 - 7162*q^84 - 115394*q^85 - 157870*q^86 + 144342*q^87 - 33506*q^88 + 112199*q^89 + 120848*q^90 - 31416*q^91 + 34873*q^92 - 117443*q^93 + 142162*q^94 - 15258*q^95 - 268696*q^96 - 367399*q^97 + 333808*q^98 - 76648*q^99 + 255904*q^100 + 274354*q^101 - 71636*q^102 + 77556*q^103 - 262904*q^104 + 319714*q^105 - 31184*q^106 - 599866*q^107 - 819205*q^108 + 740898*q^109 - 168685*q^110 + 561387*q^111 + 599772*q^112 - 155991*q^113 + 167040*q^114 - 567703*q^115 + 692472*q^116 - 63352*q^117
        y0 = q^-3 + 3*q^-2 + 7*q^-1 + 12 + 17*q + 26*q^2 + 19*q^3 + 37*q^4 - 15*q^5 - 16*q^6 - 67*q^7 - 6*q^8 - 144*q^9 + 92*q^10 - 66*q^11 + 119*q^12 + 95*q^13 + 247*q^14 + 285*q^15 + 70*q^16 - 482*q^17 - 438*q^18 + 114*q^19 - 1363*q^20 + 700*q^21 - 451*q^22 + 527*q^23 + 390*q^24 + 2134*q^25 + 1844*q^26 + 1233*q^27 - 3650*q^28 - 2543*q^29 + 1630*q^30 - 7843*q^31 + 3296*q^32 - 2343*q^33 + 1820*q^34 + 720*q^35 + 12054*q^36 + 9339*q^37 + 8010*q^38 - 20165*q^39 - 11862*q^40 + 10414*q^41 - 35564*q^42 + 13116*q^43 - 10087*q^44 + 5604*q^45 + 136*q^46 + 54686*q^47 + 39698*q^48 + 38577*q^49 - 89266*q^50 - 48446*q^51 + 49732*q^52 - 137742*q^53 + 45048*q^54 - 38104*q^55 + 14468*q^56 - 7866*q^57 + 212664*q^58 + 148105*q^59 + 153839*q^60 - 341358*q^61 - 175458*q^62 + 197613*q^63 - 477940*q^64 + 142344*q^65 - 129932*q^66 + 34009*q^67 - 45466*q^68 + 738725*q^69 + 500402*q^70 + 541483*q^71 - 1168212*q^72 - 580198*q^73 + 692628*q^74 - 1520116*q^75 + 416928*q^76 - 408705*q^77 + 69623*q^78 - 188090*q^79 + 2349414*q^80 + 1559061*q^81 + 1732580*q^82 - 3669636*q^83 - 1777174*q^84 + 2206259*q^85 - 4511534*q^86 + 1156693*q^87 - 1202190*q^88 + 123949*q^89 - 648084*q^90 + 6957176*q^91 + 4546935*q^92 + 5145949*q^93 - 10747946*q^94 - 5110983*q^95 + 6520832*q^96 - 12632681*q^97 + 3056954*q^98 - 3343197*q^99 + 167252*q^100 - 2007473*q^101 + 19417504*q^102 + 12538702*q^103 + 14372336*q^104 - 29707806*q^105 - 13927452*q^106 + 18122806*q^107 - 33673419*q^108 + 7764803*q^109 - 8858113*q^110 + 80943*q^111 - 5729036*q^112 + 51534147*q^113 + 32961312*q^114 + 38131183*q^115 - 78159888*q^116
        return x0, y0
    elif N == 14:
